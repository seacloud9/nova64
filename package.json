{
  "name": "nova64",
  "version": "0.4.9",
  "description": "Nova64 — Ultimate 3D Fantasy Console runtime for JavaScript games powered by Three.js",
  "keywords": [
    "fantasy-console",
    "3d",
    "game-engine",
    "threejs",
    "retro",
    "games"
  ],
  "license": "MIT",
  "author": "Nova64 Contributors",
  "homepage": "https://github.com/nova64/nova64#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/nova64/nova64.git"
  },
  "bugs": {
    "url": "https://github.com/nova64/nova64/issues"
  },
  "type": "module",
  "bin": {
    "nova64": "./bin/nova64.js"
  },
  "main": "./runtime/index.js",
  "types": "./runtime/index.d.ts",
  "exports": {
    ".": {
      "types": "./runtime/index.d.ts",
      "default": "./runtime/index.js"
    },
    "./runtime/*": "./runtime/*.js",
    "./runtime/api-3d/*": "./runtime/api-3d/*.js",
    "./runtime/ui/*": "./runtime/ui/*.js"
  },
  "files": [
    "bin/",
    "dist/",
    "runtime/",
    "src/",
    "public/",
    "index.html",
    "vite.config.js",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vite build && node scripts/postbuild.js",
    "preview": "vite preview",
    "osBuild": "cd os9-shell && pnpm install && pnpm build && rm -rf ../public/os9-shell/* && mkdir -p ../public/os9-shell && cp -r dist/* ../public/os9-shell/",
    "osMobileDev": "cd os9-shell && pnpm dev",
    "osMobileBuild": "cd os9-shell && pnpm install && pnpm build && rm -rf ../public/os9-shell/* && mkdir -p ../public/os9-shell && cp -r dist/* ../public/os9-shell/",
    "deployToStarcade9": "bash scripts/deploy-starcade9.sh",
    "serveStarcade9": "npx serve ../starcade9/starcade9.github.io",
    "test": "node tests/test-cli.js",
    "test:api": "node tests/test-cli.js api",
    "test:input": "node tests/test-cli.js input",
    "test:starfox": "node tests/test-cli.js starfox",
    "test:integration": "node tests/test-cli.js integration",
    "test:voxel": "node tests/test-cli.js voxel",
    "test:resize": "node tests/test-cli.js resize",
    "test:cli": "node tests/test-cli.js cli",
    "test:web": "open tests/test-runner.html || xdg-open tests/test-runner.html || start tests/test-runner.html",
    "test:all": "pnpm run test && pnpm run test:api && pnpm run test:input && pnpm run test:starfox && pnpm run test:integration",
    "test:watch": "nodemon --watch runtime --watch tests --watch examples --exec 'pnpm run test'",
    "bench": "node tests/bench.js",
    "bench:material": "node tests/bench.js --suite=material",
    "bench:instancing": "node tests/bench.js --suite=instancing",
    "bench:mesh": "node tests/bench.js --suite=mesh",
    "lint": "eslint 'runtime/**/*.js' 'src/**/*.js' --max-warnings=0",
    "lint:examples": "eslint 'examples/*/code.js' --no-eslintrc --env browser,es2021 --parser-options=ecmaVersion:latest,sourceType:module --global nova64 --global THREE --rule 'no-redeclare: error' --max-warnings=0",
    "lint:fix": "eslint 'runtime/**/*.js' 'src/**/*.js' --fix",
    "format": "prettier --write \"**/*.{js,json,md}\"",
    "format:check": "prettier --check \"**/*.{js,json,md}\"",
    "validate": "pnpm run format:check && pnpm run lint && pnpm run test:all",
    "clean": "rm -rf dist node_modules",
    "reinstall": "pnpm run clean && pnpm install",
    "prepare": "husky",
    "prepublishOnly": "pnpm run validate && pnpm run build",
    "release:patch": "pnpm version patch && git push && git push --tags",
    "release:minor": "pnpm version minor && git push && git push --tags",
    "release:major": "pnpm version major && git push && git push --tags"
  },
  "dependencies": {
    "@inquirer/prompts": "^8.4.1",
    "three": "^0.182.0",
    "vite": "^5.4.0",
    "zustand": "^5.0.11"
  },
  "devDependencies": {
    "eslint": "^8.57.1",
    "husky": "^9.1.7",
    "lint-staged": "^16.4.0",
    "nodemon": "^3.1.10",
    "prettier": "^3.6.2",
    "terser": "^5.46.0"
  },
  "lint-staged": {
    "runtime/**/*.js": [
      "eslint --max-warnings=0",
      "prettier --write"
    ],
    "src/**/*.js": [
      "eslint --max-warnings=0",
      "prettier --write"
    ],
    "examples/**/*.js": [
      "eslint --no-eslintrc --env browser,es2021 --parser-options=ecmaVersion:latest,sourceType:module --global nova64 --global THREE --rule 'no-redeclare: error' --max-warnings=0",
      "prettier --write"
    ]
  },
  "eslintConfig": {
    "env": {
      "browser": true,
      "es2021": true,
      "node": true
    },
    "extends": "eslint:recommended",
    "parserOptions": {
      "ecmaVersion": "latest",
      "sourceType": "module"
    },
    "rules": {
      "no-unused-vars": [
        "warn",
        {
          "argsIgnorePattern": "^_"
        }
      ],
      "no-console": "off",
      "no-undef": "warn"
    },
    "globals": {
      "THREE": "readonly",
      "nova64": "readonly",
      "novaLogger": "readonly"
    }
  },
  "prettier": {
    "semi": true,
    "singleQuote": true,
    "tabWidth": 2,
    "trailingComma": "es5",
    "printWidth": 100,
    "arrowParens": "avoid"
  }
}
